<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Logo Manager - Logs</title>
  <style>
    /* Reset some default styles */
    * {
      box-sizing: border-box;
    }

    body {
      margin: 20px;
      font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
      background: linear-gradient(135deg, #667eea, #764ba2);
      display: flex;
      justify-content: center;
    }

    .container {
      background: #f0f0f0;
      padding: 40px 30px;
      border-radius: 15px;
      max-width: 950px;
      width: 100%;
      box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    h1 {
      text-align: center;
      margin-bottom: 10px;
      font-size: 2.2rem;
      color: #333;
    }

    h2 {
      text-align: center;
      margin-bottom: 15px;
      font-size: 1.5rem;
      color: #555;
    }

    /* Back button styling */
    a.back-btn {
      display: inline-block;
      margin-bottom: 20px;
      padding: 8px 16px;
      background-color: #007bff;
      color: #fff;
      border-radius: 8px;
      text-decoration: none;
      transition: background-color 0.2s;
    }
    a.back-btn:hover {
      background-color: #0056b3;
    }

    /* Table styling similar to your index */
    table {
      width: 100%;
      border-collapse: collapse;
      border: 2px solid #ccc;
      border-radius: 8px;
      overflow: hidden;
      box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    thead {
      background-color: #e9ecef;
    }

    th, td {
      padding: 12px 15px;
      border-bottom: 1px solid #ccc;
      text-align: left;
    }

    tbody tr:hover {
      background-color: #f1f1f1;
    }

    /* Responsive font size */
    @media(max-width: 600px){
      table {
        font-size: 0.9rem;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <a href="/" class="back-btn">← Back to Dashboard</a>
    <h1>Logs for "<%= pixel.name %>"</h1>
    <h2>Created at: <%= new Date(pixel.createdAt).toLocaleString() %></h2>



    <!-- Define the date formatter function at the top of the template -->
    <%
      const months = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
      function formatDateTime(isoString) {
        const d = new Date(isoString);
        let day  = d.getDate();
        let mon  = months[d.getMonth()];
        let year = d.getFullYear();

        let hours   = d.getHours();
        let minutes = d.getMinutes();
        let seconds = d.getSeconds();

        let ampm = (hours >= 12) ? "pm" : "am";
        hours = (hours === 0) ? 12 : (hours > 12 ? hours - 12 : hours);
        const pad = (num) => num.toString().padStart(2, "0");
        return `${pad(day)}-${mon}-${year} ${pad(hours)}:${pad(minutes)}:${pad(seconds)}${ampm}`;
      }

      // Initialize variables for color grouping
      const rowColors = ["#ffeeee", "#eeffee", "#eeeeff", "#fff0f0", "#f0fff0", "#f0f0ff"];
      let colorIndex = 0;
      let lastTime = null;

      // Sort logs oldest to newest
      const sortedLogs = logs.slice().reverse();
    %>

    <table>
      <colgroup>
        <col style="width: 220px;" />
        <col style="width: 160px;" />
        <col style="width: auto;" />
      </colgroup>
      <thead>
        <tr>
          <th>Time</th>
          <th>IP</th>
          <th>User-Agent</th>
        </tr>
      </thead>
      <tbody>
        <% sortedLogs.forEach((log) => {
          const currentTime = new Date(log.time).getTime();
          if (lastTime !== null) {
            const diff = currentTime - lastTime;
            if (diff > 2000) {
              colorIndex = (colorIndex + 1) % rowColors.length;
            }
          }
          lastTime = currentTime;
          const formatted = formatDateTime(log.time);
          const rowColor = rowColors[colorIndex];
        %>
        <tr style="background-color: <%= rowColor %>;">
          <td><%= formatted %></td>
          <td><%= log.ip %></td>
          <td><%= log.userAgent %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</body>
</html>
